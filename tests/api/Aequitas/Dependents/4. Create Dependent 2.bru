meta {
  name: Create Dependent 2
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/dependents/
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "first_name": "Anna",
    "last_name": "Muster",
    "address": "Mustergasse 1",
    "city": "Zürich",
    "postal_code": "8000",
    "main_diagnosis": "ADHD",
    "ahv_number": "756.9876.5432.10"
  }
}

assert {
  res.status: eq 201
  res.body.first_name: eq Anna
}