meta {
  name: Create Dependent 1
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/dependents/
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "first_name": "Hans",
    "last_name": "Muster",
    "address": "Mustergasse 1",
    "city": "Zürich",
    "postal_code": "8000",
    "main_diagnosis": "Autism",
    "ahv_number": "756.1234.5678.90"
  }
}

assert {
  res.status: eq 201
  res.body.first_name: eq Hans
}