meta {
  name: Profile Positive
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/users/profile/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

assert {
  res.status: eq 200
  res.body.username: isDefined
  res.body.email: isDefined
  res.body.profile_picture: isDefined
}
