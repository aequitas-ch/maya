meta {
  name: Create Translation
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/translations/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "key": "welcome_message",
    "en": "Welcome!",
    "de": "Willkommen!"
  }
}

vars:post-response {
  translation_id: res.body.id
}

assert {
  res.status: eq 201
  res.body.key: eq "welcome_message"
}
