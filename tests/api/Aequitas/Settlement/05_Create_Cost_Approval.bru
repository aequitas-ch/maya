meta {
  name: 3. Create Cost Approval
  type: http
  seq: 6
}

post {
  url: {{base_url}}/api/settlement/cost-approvals/
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "dependent_id": {{dependent_id_1}},
    "ordering_institution_id": {{inst_id}},
    "executing_institution_id": {{inst_id}},
    "insurance_id": {{ins_id}},
    "next_reminder": "2024-12-31",
    "approved_amount": "5000.00",
    "settled_amount": "1500.00"
  }
}

vars:post-response {
  ca_id: res.body.id
}

assert {
  res.status: eq 201
  res.body.open_amount: eq "3500.00"
}