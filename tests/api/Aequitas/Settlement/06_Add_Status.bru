meta {
  name: 4. Add Status
  type: http
  seq: 7
}

post {
  url: {{base_url}}/api/settlement/cost-approvals/{{ca_id}}/add_status/
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "status": "genehmigt",
    "date": "2024-01-15"
  }
}

assert {
  res.status: eq 201
  res.body.statuses.length: gt 0
  res.body.statuses[0].status: eq "genehmigt"
}