meta {
  name: 1. Setup Institution
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/settlement/institutions/
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "name": "IV-Stelle Zürich"
  }
}

vars:post-response {
  inst_id: res.body.id
}

assert {
  res.status: eq 201
  res.body.name: eq "IV-Stelle Zürich"
}