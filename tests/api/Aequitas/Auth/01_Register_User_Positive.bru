meta {
  name: Register User Positive
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/users/register/
  body: json
  auth: none
}

body:json {
  {
    "username": "api_testuser_{{timestamp}}",
    "email": "api_testuser_{{timestamp}}@example.com",
    "first_name": "API",
    "last_name": "Tester",
    "password": "StrongPassword123!",
    "display_name": "API Tester Display"
  }
}

script:pre-request {
  const timestamp = Math.floor(Date.now() / 1000);
  bru.setVar("timestamp", timestamp);
}

script:post-response {
  if (res.status === 201) {
    const timestamp = bru.getVar("timestamp");
    bru.setVar("test_username", "api_testuser_" + timestamp);
    bru.setVar("test_email", "api_testuser_" + timestamp + "@example.com");
    bru.setVar("test_password", "StrongPassword123!");
  }
}

assert {
  res.status: eq 201
  res.body.username: isDefined
  res.body.email: isDefined
}
