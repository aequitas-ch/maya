meta {
  name: 3. Get Health Records
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/health/records/?dependent_id=1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("Should retrieve health records", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("Should contain created record", function() {
    const data = res.getBody();
    expect(data.length).to.be.greaterThan(0);
    expect(data[0].value).to.equal("45.5");
  });
}
