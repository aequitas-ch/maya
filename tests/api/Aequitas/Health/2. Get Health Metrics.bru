meta {
  name: 2. Get Health Metrics
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/health/metrics/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("Should retrieve health metrics", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("Should contain created metric", function() {
    const data = res.getBody();
    expect(data.length).to.be.greaterThan(0);
    expect(data[0].name).to.equal("Weight");
  });
}
